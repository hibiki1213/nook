{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nook",
  "version": "0.2.0",
  "identifier": "com.nook.app",
  "build": {
    "beforeDevCommand": "pnpm build:mcpb && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:mcpb && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Nook",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../mcp-server/nook.mcpb": "nook.mcpb"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hibiki1213/nook/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NUVGMTE2QzRGMzRDRkMKUldUOFRQUEVGdkZlNlRIL0dWU1BHTzc0WWhBSHJXbW5XVERkT0FEREswcHpRUE9PRVg5OTZ5a2QK"
    }
  }
}
